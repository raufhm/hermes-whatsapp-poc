# Environment Configuration for Hermes Agent

# OpenRouter API Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here

# WhatsApp Configuration
WHATSAPP_ENABLED=true
WHATSAPP_MODE=bot
WHATSAPP_ALLOWED_USERS=*
WHATSAPP_ALLOW_ALL_USERS=
WHATSAPP_DEBUG=false

# Model Configuration
HERMES_MODEL=nousresearch/hermes-3-llama-3.1-70b

# Debug mode
HERMES_DEBUG=false

# EC2 SSH Configuration
# Replace these with your actual EC2 instance details
EC2_HOST=your_ec2_host_or_ip
EC2_USER=ubuntu
EC2_KEY_FILE=ec2-whatsapp.pem
EC2_KEY_PATH=./keys/ec2-whatsapp.pem  # Must match the actual path to your PEM file on host

# Note: The PEM file will be mounted from EC2_KEY_PATH (host) to /opt/keys/EC2_KEY_FILE (container)

# Environment (dev, stg, prd)
ENV=dev

# Custom config file (optional)
HERMES_CONFIG_FILE=config-dev.yaml
